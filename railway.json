{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "dockerfile",
    "dockerfilePath": "./infra/Dockerfile",
    "context": "."
  },
  "deploy": {
    "restartPolicyType": "always",
    "restartPolicyMaxRetries": 10,
    "numReplicas": 1,
    "startCommand": "ndd-server"
  }
}
